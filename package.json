{
  "name": "color-theme-patrikovy-barvicky",
  "displayName": "Patrikovy barvičky",
  "description": "Patrikovy krásné barvičky a fonty.",
  "version": "0.4.1",
  "repository": "https://github.com/PatrikHelta/patrikovy-barvicky",
  "engines": {
    "vscode": "^1.105.1"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Patrikovy barvičky Grey",
        "uiTheme": "vs-dark",
        "path": "./themes/grey.json"
      },
      {
        "label": "Patrikovy barvičky Blue",
        "uiTheme": "vs-dark",
        "path": "./themes/blue.json"
      },
      {
        "label": "Patrikovy barvičky LEGACY",
        "uiTheme": "vs-dark",
        "path": "./themes/original.json"
      }
    ],
    "configurationDefaults": {
      "editor.fontFamily": "'OperatorMonoSSmLig Nerd Font Mono', 'OperatorMonoLig Nerd Font Mono', 'Operator Mono SSm Lig', 'Operator Mono Lig', 'Fira Code', monospace",
      "editor.fontWeight": "100",
      "editor.fontSize": 16,
      "editor.lineHeight": 19,
      "editor.fontLigatures": true,
      "editor.renderWhitespace": "selection",
      "editor.foldingImportsByDefault": false,
      "editor.accessibilitySupport": "off",
      "editor.minimap.enabled": true,
      "workbench.layoutControl.enabled": false,
      "terminal.integrated.fontFamily": "'OperatorMonoSSmLig Nerd Font Mono', 'OperatorMonoLig Nerd Font Mono', 'CaskaydiaCove Nerd Font Mono'",
      "terminal.integrated.fontSize": 14,
      "terminal.integrated.fontWeightBold": "400",
      "terminal.integrated.fontWeight": "100"
    }
  }
}
